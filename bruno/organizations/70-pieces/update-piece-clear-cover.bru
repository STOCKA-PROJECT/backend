meta {
  name: Update Piece (clear cover image)
  type: http
  seq: 24
}

patch {
  url: {{baseUrl}}/organizations/{{orgId}}/pieces/{{pieceId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{JWTtoken}}
}

body:json {
  {
    "clearCover": true
  }
}
