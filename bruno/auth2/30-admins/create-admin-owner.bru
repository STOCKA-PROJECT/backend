meta {
  name: Create Admin (OWNER)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/admins
  body: json
  auth: basic
}

auth:basic {
  username: {{ownerEmail}}
  password: {{ownerPassword}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "API Admin",
    "email": "{{adminEmail}}",
    "password": "{{adminPassword}}"
  }
}
