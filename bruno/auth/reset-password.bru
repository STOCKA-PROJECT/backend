meta {
  name: Reset Password
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/auth/reset-password
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "{{passwordResetToken}}",
    "newPassword": "12345678",
    "repeatPassword": "12345678"
  }
}

vars:pre-request {
  passwordResetToken: B3QdUat4rpbIHPnxuY6T91K54zFtWzn0WfSVvh8lecQ
}
