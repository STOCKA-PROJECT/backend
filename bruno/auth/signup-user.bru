meta {
  name: Signup User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/signup
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "test",
    "name": "Test",
    "lastName": "Test2",
    "email": "{{userEmail}}",
    "password": "{{userPassword}}",
    "repeatPassword": "{{userPassword}}"
  }
}
