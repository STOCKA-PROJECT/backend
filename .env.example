# Database
DB_HOST=localhost
DB_PORT=3307
DB_NAME=stockadb
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_db_root_password

# Security
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_strong_random_hex_string
JWT_EXPIRATION_TIME=86400000

# Email
# Options for EMAIL_PROVIDER:
#   - resend
#   - smtp  → uses SMTP_* config below. In dev, MailHog (docker compose up) at localhost:1025, UI at http://localhost:8025.
#   - local → renders templates and dumps HTML files to target/emails/ (no SMTP needed, useful in CI).
EMAIL_PROVIDER=resend
EMAIL_FROM=onboarding@resend.dev
RESEND_API_KEY=your_resend_api_key_here
RESEND_WEBHOOK_SECRET=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_AUTH=false
SMTP_STARTTLS=false
FRONTEND_BASE_URL=http://localhost:3002

# Swagger UI (dev only). Leave false in production.
# When enabled: UI at http://localhost:9095/swagger-ui.html
SWAGGER_ENABLED=true

# Sentry (error monitoring). Leave SENTRY_DSN empty to disable.
# Get the DSN from https://sentry.io > Project Settings > Client Keys (DSN).
SENTRY_DSN=https://5dd0cb4b1cae841048bc70cc78c7cf94@o4511302617464832.ingest.de.sentry.io/4511302629064784
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=local

# Cloudflare R2 (S3-compatible storage para imágenes y documentos de piezas)
R2_USE_LOCAL=false
R2_BUCKET=stocka
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_PRESIGNED_TTL=5
