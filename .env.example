# Database
DB_HOST=localhost
DB_PORT=3307
DB_NAME=stockadb
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_db_root_password

# Security
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_strong_random_hex_string
JWT_EXPIRATION_TIME=86400000

# Email
# Options for EMAIL_PROVIDER:
#   - smtp  → uses SMTP_* config below. In dev, MailHog (docker compose up) at localhost:1025, UI at http://localhost:8025.
#   - local → renders templates and dumps HTML files to target/emails/ (no SMTP needed, useful in CI).
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@stocka.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
FRONTEND_BASE_URL=http://localhost:5173

# Swagger UI (dev only). Leave false in production.
# When enabled: UI at http://localhost:9095/swagger-ui.html
SWAGGER_ENABLED=true
